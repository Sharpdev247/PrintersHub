# Kamal secrets ‚Äî safe to commit (reads from ENV, never stores raw values).
# Set these in your shell, CI/CD (GitHub Actions secrets), or a password manager
# before running `bin/kamal deploy` or `bin/kamal setup`.
#
# Required:
#   KAMAL_REGISTRY_PASSWORD   ‚Äî Docker registry access token
#   RAILS_MASTER_KEY          ‚Äî contents of config/master.key (never commit that file)
#   DATABASE_URL              ‚Äî full postgres:// connection string for production
#
# Optional (features silently disabled if absent):
#   ANTHROPIC_API_KEY         ‚Äî Claude AI key
#   SMTP_ADDRESS / SMTP_PORT / SMTP_USERNAME / SMTP_PASSWORD
#   DEVISE_MAILER_SENDER

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || echo "$RAILS_MASTER_KEY")
DATABASE_URL=$DATABASE_URL
ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY
SMTP_ADDRESS=$SMTP_ADDRESS
SMTP_PORT=$SMTP_PORT
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD
DEVISE_MAILER_SENDER=$DEVISE_MAILER_SENDER
