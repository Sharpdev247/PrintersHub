# Copy this file to .env and fill in values for your local environment
# Never commit .env — it's gitignored

DB_HOST=localhost
DB_PORT=5432

# Rails
RAILS_MAX_THREADS=5

# Devise
DEVISE_MAILER_SENDER=no-reply@printershub.com

# Anthropic (AI features)
# ANTHROPIC_API_KEY=sk-ant-...

# Production only
# DATABASE_URL=postgres://user:password@host/printershub_production
# RAILS_MASTER_KEY=                    # config/master.key — never commit
# SECRET_KEY_BASE=                     # auto-derived from RAILS_MASTER_KEY in prod

# GitHub Actions secrets required for CI/CD:
#   RAILS_MASTER_KEY       — config/master.key contents
#   SECRET_KEY_BASE        — production secret key base (optional if RAILS_MASTER_KEY set)
#   DOCKER_REGISTRY_USER   — Docker Hub or registry username
#   DOCKER_REGISTRY_TOKEN  — Docker Hub access token
#   DEPLOY_SSH_KEY         — private SSH key for Kamal deploy target servers
#   ANTHROPIC_API_KEY      — optional; AI features silently disabled if absent
