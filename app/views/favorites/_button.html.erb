<%#
  Renders a save/unsave heart button for a listing.
  Usage: render "favorites/button", listing: listing
%>
<% saved = user_signed_in? && current_user.favorites.exists?(listing: listing) %>

<% if user_signed_in? %>
  <%= button_to listing_favorite_path(listing),
        method: :post,
        title: saved ? "Remove from saved" : "Save listing",
        style: "background:#{saved ? '#fee2e2' : '#f3f4f6'};border:1px solid #{saved ? '#fca5a5' : '#e5e7eb'};
                border-radius:7px;padding:.4rem .65rem;cursor:pointer;font-size:1rem;line-height:1" do %>
    <%= saved ? "♥" : "♡" %>
  <% end %>
<% else %>
  <%= link_to new_user_session_path,
        title: "Sign in to save",
        style: "display:inline-block;background:#f3f4f6;border:1px solid #e5e7eb;
                border-radius:7px;padding:.4rem .65rem;font-size:1rem;text-decoration:none;line-height:1;color:#6b7280" do %>
    ♡
  <% end %>
<% end %>
