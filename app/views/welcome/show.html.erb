<% content_for :title, "Welcome — PrintersHub" %>

<style>
  .welcome-wrap { max-width: 560px; margin: 3rem auto; text-align: center; padding: 0 1rem; }
  .welcome-wrap h1 { font-size: 2rem; font-weight: 800; color: #1a1a2e; margin-bottom: .5rem; }
  .welcome-wrap p  { color: #6b7280; margin-bottom: 2.5rem; font-size: 1rem; line-height: 1.6; }
  .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem; }
  .type-card { border: 2px solid #e5e7eb; border-radius: 12px; padding: 1.75rem 1.25rem;
               cursor: pointer; text-decoration: none; color: inherit;
               transition: border-color .15s, box-shadow .15s; display: block; }
  .type-card:hover { border-color: #2563eb; box-shadow: 0 4px 12px rgba(37,99,235,.12); }
  .type-card .icon { font-size: 2.25rem; margin-bottom: .75rem; }
  .type-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: .35rem; }
  .type-card p  { font-size: .83rem; color: #6b7280; margin: 0; line-height: 1.4; }
  .skip-link { font-size: .85rem; color: #9ca3af; }
  .skip-link a { color: #6b7280; }
</style>

<div class="welcome-wrap">
  <h1>You're in! 🎉</h1>
  <p>Check your email to confirm your account, then come back to get started.<br>
     Tell us how you'll use PrintersHub:</p>

  <div class="card-grid">
    <a href="#" class="type-card">
      <div class="icon">🏪</div>
      <h3>I want to sell</h3>
      <p>List printer parts, toner, and equipment for buyers worldwide.</p>
    </a>
    <a href="#" class="type-card">
      <div class="icon">🛍</div>
      <h3>I want to buy</h3>
      <p>Find genuine and compatible parts from trusted sellers.</p>
    </a>
    <a href="#" class="type-card">
      <div class="icon">🔧</div>
      <h3>Service center</h3>
      <p>Manage repair jobs, technicians, and customer assets.</p>
    </a>
    <a href="#" class="type-card">
      <div class="icon">🏢</div>
      <h3>Enterprise</h3>
      <p>Multi-location operations, bulk purchasing, and API access.</p>
    </a>
  </div>

  <p class="skip-link">
    <%= link_to "Skip for now →", new_user_session_path %>
  </p>
</div>
