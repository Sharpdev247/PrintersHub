<% if resource.errors.any? %>
  <div class="error-messages" data-turbo-temporary>
    <strong><%= pluralize(resource.errors.count, "error") %> prevented this from saving:</strong>
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
