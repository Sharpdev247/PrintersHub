<% content_for :title, "Create Account — PrintersHub" %>

<h2>Create your account</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :account_name, "Business / Account Name" %>
    <%= f.text_field :account_name, autofocus: true,
                     placeholder: "Acme Printer Supplies",
                     value: params.dig(:user, :account_name) %>
    <p class="hint">This will be your store name on PrintersHub.</p>
  </div>

  <div class="field">
    <%= f.label :email, "Email Address" %>
    <%= f.email_field :email, autocomplete: "email",
                              placeholder: "you@example.com" %>
  </div>

  <div class="field">
    <%= f.label :password %>
    <% if @minimum_password_length %>
      <p class="hint">Minimum <%= @minimum_password_length %> characters</p>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password",
                                    placeholder: "••••••••" %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation, "Confirm Password" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
                                                 placeholder: "••••••••" %>
  </div>

  <%= f.submit "Create account", class: "btn-primary" %>
<% end %>

<div class="auth-links">
  <p>Already have an account? <%= link_to "Sign in", new_user_session_path %></p>
</div>
