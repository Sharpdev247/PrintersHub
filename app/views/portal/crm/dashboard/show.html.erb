<% content_for :title, "CRM — PrintersHub" %>

<div style="max-width:1000px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <h1 style="font-size:1.3rem;font-weight:700;color:#111;margin:0">CRM</h1>
    <%= link_to "+ New Contact", new_portal_crm_contact_path,
          style: "font-size:.85rem;padding:.45rem 1rem;background:#2563eb;color:#fff;border-radius:7px;text-decoration:none;font-weight:600" %>
  </div>

  <%# KPIs %>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem">
    <% [
      ["Total Contacts", @stats[:total],     "#374151"],
      ["Leads",          @stats[:leads],     "#2563eb"],
      ["Customers",      @stats[:customers], "#059669"],
      ["Active",         @stats[:active],    "#0891b2"],
    ].each do |label, val, color| %>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.1rem 1.25rem">
        <div style="font-size:1.5rem;font-weight:800;color:<%= color %>"><%= val %></div>
        <div style="font-size:.78rem;color:#9ca3af;margin-top:.2rem"><%= label %></div>
      </div>
    <% end %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem">
    <%# Overdue follow-ups %>
    <div style="background:#fff;border:1px solid #fca5a5;border-radius:10px;overflow:hidden">
      <div style="padding:.9rem 1.25rem;border-bottom:1px solid #fee2e2;display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:.9rem;font-weight:700;color:#dc2626">⚠️ Overdue Follow-ups</span>
        <span style="font-size:.78rem;color:#dc2626;font-weight:600"><%= @overdue_follow_ups.count %></span>
      </div>
      <% if @overdue_follow_ups.none? %>
        <div style="padding:1.5rem;text-align:center;font-size:.85rem;color:#9ca3af">No overdue follow-ups. ✓</div>
      <% else %>
        <% @overdue_follow_ups.each do |note| %>
          <%= link_to portal_crm_contact_path(note.contact),
                style: "display:block;padding:.7rem 1.25rem;border-top:1px solid #fef2f2;text-decoration:none" do %>
            <div style="font-size:.85rem;font-weight:600;color:#111"><%= note.contact.display_name %></div>
            <div style="font-size:.75rem;color:#9ca3af;margin-top:.1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
              <%= note.body.truncate(60) %>
            </div>
            <div style="font-size:.72rem;color:#dc2626;margin-top:.15rem;font-weight:600">
              Due <%= note.follow_up_at.strftime("%b %d, %Y") %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%# Upcoming follow-ups %>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
      <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:.9rem;font-weight:700;color:#111">📅 Upcoming Follow-ups</span>
        <span style="font-size:.78rem;color:#6b7280"><%= @upcoming_follow_ups.count %></span>
      </div>
      <% if @upcoming_follow_ups.none? %>
        <div style="padding:1.5rem;text-align:center;font-size:.85rem;color:#9ca3af">No upcoming follow-ups.</div>
      <% else %>
        <% @upcoming_follow_ups.each do |note| %>
          <%= link_to portal_crm_contact_path(note.contact),
                style: "display:block;padding:.7rem 1.25rem;border-top:1px solid #f9fafb;text-decoration:none" do %>
            <div style="font-size:.85rem;font-weight:600;color:#111"><%= note.contact.display_name %></div>
            <div style="font-size:.75rem;color:#9ca3af;margin-top:.1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
              <%= note.body.truncate(60) %>
            </div>
            <div style="font-size:.72rem;color:#2563eb;margin-top:.15rem;font-weight:600">
              Due <%= note.follow_up_at.strftime("%b %d, %Y") %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Recent contacts %>
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;margin-top:1.25rem">
    <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;display:flex;justify-content:space-between;align-items:center">
      <span style="font-size:.9rem;font-weight:700;color:#111">Recent Contacts</span>
      <%= link_to "All contacts →", portal_crm_contacts_path,
            style: "font-size:.78rem;color:#2563eb;text-decoration:none" %>
    </div>
    <% @recent_contacts.each do |c| %>
      <%= link_to portal_crm_contact_path(c),
            style: "display:flex;justify-content:space-between;align-items:center;padding:.75rem 1.25rem;border-top:1px solid #f9fafb;text-decoration:none" do %>
        <div>
          <div style="font-size:.88rem;font-weight:600;color:#111"><%= c.display_name %></div>
          <div style="font-size:.75rem;color:#9ca3af"><%= c.email %></div>
        </div>
        <div style="display:flex;align-items:center;gap:.5rem">
          <%
            type_badge = { "lead" => { bg: "#dbeafe", color: "#1d4ed8" },
                           "customer" => { bg: "#d1fae5", color: "#065f46" },
                           "contact" => { bg: "#f3f4f6", color: "#6b7280" } }[c.contact_type]
          %>
          <span style="font-size:.72rem;padding:.15rem .55rem;border-radius:10px;font-weight:600;
                       background:<%= type_badge[:bg] %>;color:<%= type_badge[:color] %>">
            <%= c.contact_type.humanize %>
          </span>
          <span style="font-size:.75rem;color:#9ca3af"><%= c.owner&.email&.split("@")&.first %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
