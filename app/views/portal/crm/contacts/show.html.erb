<% content_for :title, "#{@contact.display_name} — CRM" %>

<%
  NOTE_ICON = { "note"=>"📝","call"=>"📞","email"=>"✉️","meeting"=>"🤝","follow_up"=>"🔔" }.freeze
  TYPE_BADGE = {
    "lead"=>{bg:"#dbeafe",color:"#1d4ed8"},
    "customer"=>{bg:"#d1fae5",color:"#065f46"},
    "contact"=>{bg:"#f3f4f6",color:"#6b7280"},
  }.freeze
  badge = TYPE_BADGE[@contact.contact_type] || TYPE_BADGE["contact"]
%>

<div style="max-width:860px">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem">
    <div>
      <%= link_to "← Contacts", portal_crm_contacts_path, style: "font-size:.82rem;color:#6b7280;text-decoration:none" %>
      <h1 style="font-size:1.25rem;font-weight:700;color:#111;margin:.3rem 0 .2rem"><%= @contact.display_name %></h1>
      <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
        <span style="font-size:.78rem;padding:.2rem .65rem;border-radius:20px;font-weight:600;
                     background:<%= badge[:bg] %>;color:<%= badge[:color] %>">
          <%= @contact.contact_type.humanize %>
        </span>
        <span style="font-size:.78rem;color:#9ca3af"><%= @contact.source&.humanize %></span>
      </div>
    </div>
    <% if policy(@contact).update? %>
      <%= link_to "Edit", edit_portal_crm_contact_path(@contact),
            style: "font-size:.82rem;padding:.4rem .9rem;background:#f3f4f6;color:#374151;border:1px solid #e5e7eb;border-radius:7px;text-decoration:none;font-weight:600" %>
    <% end %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 300px;gap:1rem;align-items:start">
    <%# Left: notes timeline %>
    <div>
      <%# Add note form %>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.25rem;margin-bottom:1rem">
        <div style="font-size:.88rem;font-weight:700;color:#111;margin-bottom:.85rem">Add Note</div>
        <%= form_with model: [@contact, @new_note],
              url: portal_crm_contact_contact_notes_path(@contact),
              method: :post do |f| %>
          <div style="display:flex;gap:.75rem;margin-bottom:.75rem">
            <%= f.select :note_type,
                  Contact::NOTE_TYPES.map { |t| [t.humanize, t] },
                  {},
                  style: "padding:.45rem .65rem;border:1px solid #d1d5db;border-radius:6px;font-size:.85rem" %>
            <%= f.datetime_local_field :follow_up_at,
                  placeholder: "Follow-up date (optional)",
                  style: "flex:1;padding:.45rem .65rem;border:1px solid #d1d5db;border-radius:6px;font-size:.85rem" %>
          </div>
          <%= f.text_area :body, rows: 3, required: true,
                placeholder: "Add a note…",
                style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.88rem;resize:vertical;margin-bottom:.6rem" %>
          <%= f.submit "Save Note",
                style: "padding:.5rem 1.1rem;background:#2563eb;color:#fff;border:none;border-radius:6px;font-size:.85rem;font-weight:600;cursor:pointer" %>
        <% end %>
      </div>

      <%# Notes timeline %>
      <% if @notes.any? %>
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
          <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.88rem;font-weight:700;color:#111">
            Activity (<%= @notes.count %>)
          </div>
          <% @notes.each do |note| %>
            <div style="padding:.9rem 1.25rem;border-top:1px solid #f9fafb;display:flex;gap:.75rem">
              <div style="font-size:1.1rem;flex-shrink:0;padding-top:.1rem"><%= NOTE_ICON[note.note_type] || "📌" %></div>
              <div style="flex:1;min-width:0">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem">
                  <div style="font-size:.82rem;font-weight:600;color:#374151"><%= note.note_type.humanize %></div>
                  <div style="font-size:.72rem;color:#9ca3af;flex-shrink:0">
                    <%= note.created_at.strftime("%b %d, %Y %I:%M %p") %>
                  </div>
                </div>
                <div style="font-size:.88rem;color:#111;margin-top:.25rem;white-space:pre-wrap"><%= note.body %></div>
                <% if note.follow_up_at %>
                  <div style="font-size:.75rem;margin-top:.3rem;font-weight:600;
                               color:<%= note.follow_up_at < Time.current ? '#dc2626' : '#2563eb' %>">
                    🔔 Follow-up: <%= note.follow_up_at.strftime("%b %d, %Y") %>
                    <%= note.follow_up_at < Time.current ? " (overdue)" : "" %>
                  </div>
                <% end %>
                <div style="font-size:.72rem;color:#9ca3af;margin-top:.2rem">
                  by <%= note.author.email %>
                  <% if policy(@contact).update? %>
                    ·
                    <%= button_to "Delete", portal_crm_contact_note_path(note),
                          method: :delete,
                          data: { confirm: "Delete this note?" },
                          style: "background:none;border:none;color:#9ca3af;font-size:.72rem;cursor:pointer;padding:0;text-decoration:underline" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Right: contact info %>
    <div>
      <div style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:10px;padding:1rem">
        <div style="font-size:.72rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.6rem">Contact Info</div>
        <% {
          "Email"         => @contact.email,
          "Phone"         => @contact.phone,
          "Company"       => @contact.company_name,
          "Source"        => @contact.source&.humanize,
          "Status"        => @contact.status.humanize,
          "Owner"         => @contact.owner&.email,
          "Last Contact"  => @contact.last_contacted_at&.strftime("%b %d, %Y") || "Never",
          "Notes Count"   => @notes.count.to_s,
          "Created"       => @contact.created_at.strftime("%b %d, %Y"),
        }.each do |label, val| %>
          <% next if val.blank? %>
          <div style="display:flex;justify-content:space-between;font-size:.82rem;padding:.3rem 0;border-bottom:1px solid #f3f4f6">
            <span style="color:#9ca3af"><%= label %></span>
            <span style="color:#374151;font-weight:500;text-align:right;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
              <%= val %>
            </span>
          </div>
        <% end %>
      </div>

      <% if @contact.notes.present? %>
        <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:1rem;margin-top:.75rem">
          <div style="font-size:.72rem;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.4rem">Profile Notes</div>
          <div style="font-size:.85rem;color:#78350f;white-space:pre-wrap"><%= @contact.notes %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>
