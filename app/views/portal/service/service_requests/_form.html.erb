<%= form_with model: @request,
      url: @request.new_record? ? portal_service_service_requests_path : portal_service_service_request_path(@request),
      method: @request.new_record? ? :post : :patch do |f| %>

  <% if @request.errors.any? %>
    <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:.875rem;margin-bottom:1.25rem">
      <% @request.errors.full_messages.each do |msg| %>
        <div style="font-size:.85rem;color:#dc2626"><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div style="margin-bottom:1rem">
    <%= f.label :title, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
    <%= f.text_field :title, required: true,
          style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem" %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
    <div>
      <%= f.label :priority, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
      <%= f.select :priority, ServiceRequest::PRIORITIES.map { |p| [p.humanize, p] },
            { selected: @request.priority || "normal" },
            style: "width:100%;padding:.55rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem" %>
    </div>
    <div>
      <%= f.label :status, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
      <%= f.select :status, ServiceRequest::STATUSES.map { |s| [s.humanize, s] },
            { selected: @request.status || "pending" },
            style: "width:100%;padding:.55rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem" %>
    </div>
  </div>

  <div style="margin-bottom:1rem">
    <%= f.label :description, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
    <%= f.text_area :description, rows: 3,
          style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;resize:vertical",
          placeholder: "Describe the problem…" %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
    <div>
      <%= f.label :printer_model_id, "Printer Model", style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
      <%= f.select :printer_model_id, PrinterModel.order(:name).map { |m| [m.name, m.id] },
            { include_blank: "— Select model —" },
            style: "width:100%;padding:.55rem;border:1px solid #d1d5db;border-radius:6px;font-size:.88rem" %>
    </div>
    <div>
      <%= f.label :serial_number, "Serial Number", style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
      <%= f.text_field :serial_number,
            style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;font-family:monospace" %>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
    <div>
      <%= f.label :estimated_cost, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
      <%= f.number_field :estimated_cost, step: "0.01", min: 0,
            style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem" %>
    </div>
    <div>
      <%= f.label :currency, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
      <%= f.text_field :currency, maxlength: 3, placeholder: "USD",
            style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;font-family:monospace;text-transform:uppercase" %>
    </div>
  </div>

  <div style="margin-bottom:1rem">
    <%= f.label :scheduled_at, "Scheduled Date", style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
    <%= f.datetime_local_field :scheduled_at,
          style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem" %>
  </div>

  <div style="margin-bottom:1rem">
    <%= f.label :diagnosis, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
    <%= f.text_area :diagnosis, rows: 2,
          style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;resize:vertical" %>
  </div>

  <div style="margin-bottom:1rem">
    <%= f.label :resolution, style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
    <%= f.text_area :resolution, rows: 2,
          style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;resize:vertical" %>
  </div>

  <div style="margin-bottom:1.5rem">
    <%= f.label :notes, "Internal Notes", style: "display:block;font-size:.82rem;font-weight:600;color:#555;margin-bottom:.3rem" %>
    <%= f.text_area :notes, rows: 2,
          style: "width:100%;padding:.55rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.9rem;resize:vertical;background:#fffbeb" %>
  </div>

  <div style="display:flex;gap:.75rem">
    <%= f.submit @request.new_record? ? "Create Request" : "Save Changes",
          style: "padding:.6rem 1.5rem;background:#2563eb;color:#fff;border:none;border-radius:7px;font-size:.9rem;font-weight:600;cursor:pointer" %>
    <%= link_to "Cancel",
          @request.new_record? ? portal_service_service_requests_path : portal_service_service_request_path(@request),
          style: "padding:.6rem 1rem;font-size:.9rem;color:#6b7280;text-decoration:none" %>
  </div>
<% end %>
