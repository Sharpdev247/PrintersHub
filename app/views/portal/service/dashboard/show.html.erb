<% content_for :title, "Service Center — PrintersHub" %>

<%
  STATUS_COLOR = {
    "pending"       => { bg: "#f3f4f6", color: "#6b7280" },
    "scheduled"     => { bg: "#dbeafe", color: "#1d4ed8" },
    "in_progress"   => { bg: "#ede9fe", color: "#5b21b6" },
    "diagnosed"     => { bg: "#fef3c7", color: "#92400e" },
    "waiting_parts" => { bg: "#ffedd5", color: "#9a3412" },
    "completed"     => { bg: "#d1fae5", color: "#065f46" },
    "cancelled"     => { bg: "#fee2e2", color: "#991b1b" },
  }.freeze
  PRIORITY_COLOR = {
    "urgent" => "#dc2626", "high" => "#d97706",
    "normal" => "#6b7280", "low"  => "#9ca3af"
  }.freeze
%>

<div style="max-width:1000px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <h1 style="font-size:1.3rem;font-weight:700;color:#111;margin:0">Service Center</h1>
    <%= link_to "+ New Request", new_portal_service_service_request_path,
          style: "font-size:.85rem;padding:.45rem 1rem;background:#2563eb;color:#fff;border-radius:7px;text-decoration:none;font-weight:600" %>
  </div>

  <%# KPI row %>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem">
    <% [
      ["Open",           @stats[:open],            "#2563eb"],
      ["In Progress",    @stats[:in_progress],      "#5b21b6"],
      ["Urgent",         @stats[:urgent],           "#dc2626"],
      ["Overdue",        @stats[:overdue],          "#d97706"],
    ].each do |label, val, color| %>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.1rem 1.25rem">
        <div style="font-size:1.5rem;font-weight:800;color:<%= color %>"><%= val %></div>
        <div style="font-size:.78rem;color:#9ca3af;margin-top:.2rem"><%= label %></div>
      </div>
    <% end %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem">
    <%# Open requests %>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
      <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:.9rem;font-weight:700;color:#111">Open Requests</span>
        <%= link_to "All →", portal_service_service_requests_path,
              style: "font-size:.78rem;color:#2563eb;text-decoration:none" %>
      </div>
      <% if @recent.none? %>
        <div style="padding:1.5rem;text-align:center;font-size:.85rem;color:#9ca3af">No open requests.</div>
      <% else %>
        <% @recent.each do |sr| %>
          <% sc = STATUS_COLOR[sr.status] || STATUS_COLOR["pending"] %>
          <%= link_to portal_service_service_request_path(sr),
                style: "display:block;padding:.75rem 1.25rem;border-top:1px solid #f9fafb;text-decoration:none" do %>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem">
              <div style="flex:1;min-width:0">
                <div style="font-size:.85rem;font-weight:600;color:#111;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  <%= sr.title %>
                </div>
                <div style="font-size:.73rem;color:#9ca3af;margin-top:.15rem">
                  <span style="font-family:monospace"><%= sr.request_number %></span>
                  <% if sr.assigned_to %>
                    · <%= sr.assigned_to.email %>
                  <% else %>
                    · <span style="color:#d97706">Unassigned</span>
                  <% end %>
                </div>
              </div>
              <div style="flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:.25rem">
                <span style="font-size:.72rem;padding:.15rem .5rem;border-radius:10px;font-weight:600;
                             background:<%= sc[:bg] %>;color:<%= sc[:color] %>">
                  <%= sr.status.humanize %>
                </span>
                <span style="font-size:.7rem;font-weight:600;color:<%= PRIORITY_COLOR[sr.priority] %>">
                  <%= sr.priority.upcase %>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%# My assignments + team %>
    <div style="display:flex;flex-direction:column;gap:1rem">
      <%# Assigned to me %>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
        <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.9rem;font-weight:700;color:#111">
          My Assignments (<%= @my_requests.count %>)
        </div>
        <% if @my_requests.none? %>
          <div style="padding:1.25rem;font-size:.85rem;color:#9ca3af;text-align:center">No requests assigned to you.</div>
        <% else %>
          <% @my_requests.each do |sr| %>
            <% sc = STATUS_COLOR[sr.status] || STATUS_COLOR["pending"] %>
            <%= link_to portal_service_service_request_path(sr),
                  style: "display:flex;justify-content:space-between;padding:.65rem 1.25rem;border-top:1px solid #f9fafb;text-decoration:none" do %>
              <div style="font-size:.85rem;font-weight:600;color:#111;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0">
                <%= sr.title %>
              </div>
              <span style="font-size:.72rem;padding:.15rem .5rem;border-radius:10px;font-weight:600;flex-shrink:0;margin-left:.5rem;
                           background:<%= sc[:bg] %>;color:<%= sc[:color] %>">
                <%= sr.status.humanize %>
              </span>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <%# Technician team %>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
        <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.9rem;font-weight:700;color:#111">
          Technicians (<%= @technicians.count %>)
        </div>
        <% if @technicians.none? %>
          <div style="padding:1.25rem;font-size:.85rem;color:#9ca3af;text-align:center">
            No technicians. <%= link_to "Add one", portal_settings_memberships_path, style: "color:#2563eb" %>.
          </div>
        <% else %>
          <% @technicians.each do |m| %>
            <div style="padding:.65rem 1.25rem;border-top:1px solid #f9fafb;display:flex;justify-content:space-between;align-items:center">
              <div style="font-size:.85rem;color:#374151"><%= m.user.email %></div>
              <div style="font-size:.75rem;color:#9ca3af">
                <%= policy_scope(ServiceRequest).open.where(assigned_to: m.user).count %> open
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
