<% content_for :title, "My Orders — PrintersHub" %>

<div style="max-width:900px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <h1 style="font-size:1.3rem;font-weight:700;color:#111;margin:0">My Orders</h1>
    <%= link_to "Browse listings", listings_path,
          style: "font-size:.85rem;color:#2563eb;text-decoration:none;font-weight:500" %>
  </div>

  <% if @orders.none? %>
    <div style="text-align:center;padding:4rem 2rem;background:#f9fafb;border:1px dashed #d1d5db;border-radius:12px">
      <div style="font-size:2rem;margin-bottom:.75rem">📦</div>
      <div style="font-size:1rem;font-weight:600;color:#374151;margin-bottom:.5rem">No orders yet</div>
      <div style="font-size:.875rem;color:#6b7280;margin-bottom:1.5rem">
        Find printer parts and equipment on the marketplace.
      </div>
      <%= link_to "Browse listings", listings_path,
            style: "padding:.6rem 1.5rem;background:#2563eb;color:#fff;border-radius:8px;text-decoration:none;font-size:.9rem;font-weight:600" %>
    </div>
  <% else %>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
      <table style="width:100%;border-collapse:collapse">
        <thead>
          <tr style="background:#f9fafb">
            <th style="padding:.65rem 1.25rem;text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em">Order</th>
            <th style="padding:.65rem 1rem;text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em">Seller</th>
            <th style="padding:.65rem 1rem;text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em">Items</th>
            <th style="padding:.65rem 1rem;text-align:right;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em">Total</th>
            <th style="padding:.65rem 1rem;text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em">Status</th>
            <th style="padding:.65rem 1rem;text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.05em">Date</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr style="border-top:1px solid #f3f4f6">
              <td style="padding:.85rem 1.25rem">
                <%= link_to order.order_number, portal_buyer_order_path(order),
                      style: "font-size:.88rem;font-weight:700;color:#2563eb;text-decoration:none;font-family:monospace" %>
              </td>
              <td style="padding:.85rem 1rem;font-size:.85rem;color:#374151">
                <%= order.seller_account.name %>
              </td>
              <td style="padding:.85rem 1rem;font-size:.85rem;color:#6b7280">
                <%= order.order_items.size %> item<%= order.order_items.size == 1 ? "" : "s" %>
              </td>
              <td style="padding:.85rem 1rem;font-size:.9rem;font-weight:700;color:#111;text-align:right">
                <%= number_to_currency(order.total, unit: order.currency + " ") %>
              </td>
              <td style="padding:.85rem 1rem">
                <%= render "portal/shared/order_status_badge", status: order.status %>
              </td>
              <td style="padding:.85rem 1rem;font-size:.8rem;color:#9ca3af">
                <%= order.created_at.strftime("%b %d, %Y") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @orders.total_pages > 1 %>
      <div style="margin-top:1.5rem;text-align:center"><%= paginate @orders %></div>
    <% end %>
  <% end %>
</div>
