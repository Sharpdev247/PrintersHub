<% content_for :title, "Order #{@order.order_number} — PrintersHub" %>

<div style="max-width:800px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <div>
      <%= link_to "← My Orders", portal_buyer_orders_path,
            style: "font-size:.82rem;color:#6b7280;text-decoration:none" %>
      <h1 style="font-size:1.2rem;font-weight:700;color:#111;margin:.3rem 0 0">
        Order <span style="font-family:monospace"><%= @order.order_number %></span>
      </h1>
    </div>
    <%= render "portal/shared/order_status_badge", status: @order.status %>
  </div>

  <%# Order items %>
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;margin-bottom:1rem">
    <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.88rem;font-weight:700;color:#111">
      Items
    </div>
    <% @order.order_items.each do |item| %>
      <div style="padding:.9rem 1.25rem;border-top:1px solid #f9fafb;display:flex;justify-content:space-between;align-items:center;gap:1rem">
        <div style="flex:1;min-width:0">
          <div style="font-size:.9rem;font-weight:600;color:#111">
            <% snap = item.listing_snapshot %>
            <%= snap&.dig("title") || item.listing&.title || "Listing removed" %>
          </div>
          <div style="font-size:.78rem;color:#9ca3af;margin-top:.15rem">
            Qty: <%= item.quantity %> ·
            <%= number_to_currency(item.unit_price, unit: item.currency + " ") %> each
          </div>
        </div>
        <div style="font-size:.95rem;font-weight:700;color:#111;flex-shrink:0">
          <%= number_to_currency(item.total, unit: item.currency + " ") %>
        </div>
      </div>
    <% end %>

    <%# Totals %>
    <div style="padding:.9rem 1.25rem;border-top:1px solid #e5e7eb;background:#f9fafb">
      <% [
        ["Subtotal",  @order.subtotal],
        ["Tax",       @order.tax_amount],
        ["Shipping",  @order.shipping_amount],
        ["Discount",  @order.discount_amount.positive? ? -@order.discount_amount : nil],
      ].each do |label, amount| %>
        <% next unless amount %>
        <div style="display:flex;justify-content:space-between;font-size:.85rem;color:#6b7280;margin-bottom:.3rem">
          <span><%= label %></span>
          <span><%= number_to_currency(amount.abs, unit: @order.currency + " ") %></span>
        </div>
      <% end %>
      <div style="display:flex;justify-content:space-between;font-size:1rem;font-weight:700;color:#111;
                  border-top:1px solid #e5e7eb;padding-top:.5rem;margin-top:.25rem">
        <span>Total</span>
        <span><%= number_to_currency(@order.total, unit: @order.currency + " ") %></span>
      </div>
    </div>
  </div>

  <%# Seller + dates -%>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1rem">
      <div style="font-size:.75rem;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem">Seller</div>
      <div style="font-size:.9rem;font-weight:600;color:#111"><%= @order.seller_account.name %></div>
    </div>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1rem">
      <div style="font-size:.75rem;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem">Timeline</div>
      <div style="font-size:.82rem;color:#374151">Placed: <%= @order.created_at.strftime("%b %d, %Y %I:%M %p") %></div>
      <% if @order.paid_at %>
        <div style="font-size:.82rem;color:#374151">Paid: <%= @order.paid_at.strftime("%b %d, %Y %I:%M %p") %></div>
      <% end %>
      <% if @order.shipped_at %>
        <div style="font-size:.82rem;color:#374151">Shipped: <%= @order.shipped_at.strftime("%b %d, %Y %I:%M %p") %></div>
      <% end %>
    </div>
  </div>

  <%# Cancel action %>
  <% if policy(@order).cancel? && @order.cancellable? %>
    <div style="background:#fff;border:1px solid #fca5a5;border-radius:10px;padding:1.25rem">
      <div style="font-size:.88rem;font-weight:700;color:#dc2626;margin-bottom:.75rem">Cancel Order</div>
      <%= form_with url: cancel_portal_buyer_order_path(@order), method: :patch do |f| %>
        <div style="margin-bottom:.75rem">
          <%= f.text_field :reason,
                placeholder: "Reason for cancellation (optional)",
                style: "width:100%;padding:.5rem .75rem;border:1px solid #fca5a5;border-radius:6px;font-size:.88rem" %>
        </div>
        <%= f.submit "Cancel this order",
              data: { confirm: "Are you sure you want to cancel order #{@order.order_number}?" },
              style: "padding:.5rem 1.25rem;background:#fee2e2;color:#dc2626;border:1px solid #fca5a5;border-radius:6px;font-size:.88rem;font-weight:600;cursor:pointer" %>
      <% end %>
    </div>
  <% end %>
</div>
