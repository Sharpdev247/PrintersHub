<% content_for :title, "Saved Searches — PrintersHub" %>

<div style="max-width:800px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <div>
      <h1 style="font-size:1.3rem;font-weight:700;color:#111;margin:0">Saved Searches</h1>
      <div style="font-size:.85rem;color:#6b7280;margin-top:.2rem"><%= @saved_searches.count %> saved</div>
    </div>
    <%= link_to "Browse marketplace", listings_path,
          style: "font-size:.85rem;color:#2563eb;text-decoration:none;font-weight:500" %>
  </div>

  <% if @saved_searches.none? %>
    <div style="text-align:center;padding:4rem 2rem;background:#f9fafb;border:1px dashed #d1d5db;border-radius:12px">
      <div style="font-size:2rem;margin-bottom:.75rem">🔍</div>
      <div style="font-size:1rem;font-weight:600;color:#374151;margin-bottom:.5rem">No saved searches yet</div>
      <div style="font-size:.875rem;color:#6b7280;margin-bottom:1.5rem">
        Filter the marketplace and save a search to get notified when new listings match.
      </div>
      <%= link_to "Browse listings", listings_path,
            style: "padding:.6rem 1.5rem;background:#2563eb;color:#fff;border-radius:8px;text-decoration:none;font-size:.9rem;font-weight:600" %>
    </div>
  <% else %>
    <div style="display:flex;flex-direction:column;gap:.75rem">
      <% @saved_searches.each do |ss| %>
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.1rem 1.25rem;
                    display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap">

          <div style="flex:1;min-width:0">
            <div style="font-size:.95rem;font-weight:700;color:#111;margin-bottom:.3rem">
              <%= ss.name %>
            </div>

            <%# Filter chips %>
            <div style="display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:.4rem">
              <% ss.filters.each do |key, val| %>
                <% next if val.blank? %>
                <span style="font-size:.72rem;background:#f3f4f6;color:#6b7280;padding:.15rem .55rem;border-radius:10px;border:1px solid #e5e7eb">
                  <%= key.to_s.humanize %>: <%= val %>
                </span>
              <% end %>
            </div>

            <div style="font-size:.75rem;color:#9ca3af">
              Saved <%= time_ago_in_words(ss.created_at) %> ago
              <% if ss.alert_enabled? %>
                · <span style="color:#059669;font-weight:500">✓ Email alerts on</span>
              <% end %>
            </div>
          </div>

          <div style="display:flex;align-items:center;gap:.6rem;flex-shrink:0">
            <%# Run search %>
            <%= link_to listings_path(ss.filters),
                  style: "font-size:.8rem;padding:.35rem .85rem;background:#eff6ff;color:#2563eb;border:1px solid #bfdbfe;border-radius:6px;text-decoration:none;font-weight:600",
                  title: "Run this search" do %>
              Run ›
            <% end %>

            <%# Toggle alert %>
            <%= button_to toggle_alert_portal_saved_search_path(ss),
                  method: :patch,
                  title: ss.alert_enabled? ? "Turn off alerts" : "Turn on email alerts",
                  style: "font-size:.8rem;padding:.35rem .85rem;border-radius:6px;cursor:pointer;font-weight:600;
                          background:#{ss.alert_enabled? ? '#d1fae5' : '#f9fafb'};
                          color:#{ss.alert_enabled? ? '#065f46' : '#6b7280'};
                          border:1px solid #{ss.alert_enabled? ? '#6ee7b7' : '#e5e7eb'}" do %>
              <%= ss.alert_enabled? ? "🔔 Alerts on" : "🔕 Alerts off" %>
            <% end %>

            <%# Delete %>
            <%= button_to portal_saved_search_path(ss),
                  method: :delete,
                  data: { confirm: "Delete \"#{ss.name}\"?" },
                  style: "font-size:.8rem;padding:.35rem .75rem;background:#fff;color:#9ca3af;border:1px solid #e5e7eb;border-radius:6px;cursor:pointer" do %>
              ✕
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
