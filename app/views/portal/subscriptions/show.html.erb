<% content_for :title, "Subscription — PrintersHub" %>

<%
  STATUS_COLORS = {
    "trialing"  => { bg: "#ede9fe", color: "#6d28d9" },
    "active"    => { bg: "#dcfce7", color: "#15803d" },
    "past_due"  => { bg: "#fef3c7", color: "#b45309" },
    "cancelled" => { bg: "#fee2e2", color: "#dc2626" },
    "expired"   => { bg: "#f3f4f6", color: "#6b7280" },
    "suspended" => { bg: "#fee2e2", color: "#dc2626" },
  }.freeze

  FEATURE_LABELS = {
    "max_listings"           => "Listings",
    "max_team_members"       => "Team members",
    "api_access"             => "API access",
    "analytics"              => "Analytics",
    "crm_module"             => "CRM module",
    "warehouse_module"       => "Warehouse module",
    "repair_module"          => "Service/Repair module",
    "priority_notifications" => "Priority notifications",
    "storage_gb"             => "Storage",
    "support_level"          => "Support",
  }.freeze
%>

<div style="max-width:820px">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
    <h1 style="font-size:1.3rem;font-weight:700;color:#111;margin:0">Subscription</h1>
    <%= link_to "View plans →", portal_subscription_plans_path,
          style: "font-size:.85rem;color:#2563eb;text-decoration:none" %>
  </div>

  <%# Current plan card %>
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:1.5rem;margin-bottom:1.5rem">
    <% if @subscription && @plan %>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem">
        <div>
          <div style="font-size:1.2rem;font-weight:800;color:#111"><%= @plan.name %></div>
          <div style="font-size:.85rem;color:#6b7280;margin-top:.2rem">
            <%= number_to_currency(@subscription.current_price, unit: "$ ") %> /
            <%= @subscription.billing_interval %>
          </div>
        </div>

        <% sc = STATUS_COLORS[@subscription.status] || { bg: "#f3f4f6", color: "#6b7280" } %>
        <span style="background:<%= sc[:bg] %>;color:<%= sc[:color] %>;font-size:.78rem;
                     font-weight:700;padding:.3rem .85rem;border-radius:20px">
          <%= @subscription.status.humanize %>
        </span>
      </div>

      <div style="display:flex;gap:2rem;margin-top:1.1rem;flex-wrap:wrap">
        <% if @subscription.trial_ends_at&.future? %>
          <div>
            <div style="font-size:.72rem;font-weight:600;color:#9ca3af;text-transform:uppercase">Trial ends</div>
            <div style="font-size:.88rem;color:#374151"><%= @subscription.trial_ends_at.strftime("%B %-d, %Y") %></div>
          </div>
        <% end %>
        <% if @subscription.current_period_end %>
          <div>
            <div style="font-size:.72rem;font-weight:600;color:#9ca3af;text-transform:uppercase">
              Next <%= @subscription.status_cancelled? ? "access ends" : "billing" %>
            </div>
            <div style="font-size:.88rem;color:#374151">
              <%= @subscription.current_period_end.strftime("%B %-d, %Y") %>
            </div>
          </div>
        <% end %>
      </div>

      <% unless @subscription.status_cancelled? || @subscription.status_expired? %>
        <div style="margin-top:1.25rem;padding-top:1.1rem;border-top:1px solid #f3f4f6;display:flex;gap:.75rem">
          <%= link_to "Upgrade / Change plan", portal_subscription_plans_path,
                style: "padding:.42rem .9rem;background:#111;color:#fff;border-radius:6px;
                        font-size:.83rem;font-weight:600;text-decoration:none" %>
          <%= button_to "Cancel subscription", portal_subscription_path, method: :delete,
                data: { confirm: "Cancel your subscription? You'll keep access until the end of the current period." },
                style: "padding:.42rem .9rem;background:#fff;color:#dc2626;border:1px solid #fca5a5;
                        border-radius:6px;font-size:.83rem;font-weight:600;cursor:pointer" %>
        </div>
      <% end %>

    <% else %>
      <div style="text-align:center;padding:1.5rem 0">
        <div style="font-size:1rem;font-weight:700;color:#374151;margin-bottom:.5rem">No active subscription</div>
        <div style="font-size:.85rem;color:#9ca3af;margin-bottom:1.25rem">
          You're on the free tier. Upgrade to unlock more listings, team members, and modules.
        </div>
        <%= link_to "View plans", portal_subscription_plans_path,
              style: "padding:.5rem 1.25rem;background:#2563eb;color:#fff;border-radius:6px;
                      font-size:.88rem;font-weight:600;text-decoration:none" %>
      </div>
    <% end %>
  </div>

  <%# Usage meters %>
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;margin-bottom:1.5rem">
    <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.88rem;font-weight:700;color:#111">
      Usage this month
    </div>
    <div style="padding:.25rem 0">
      <% %w[max_listings max_team_members storage_gb].each do |key| %>
        <% u = @enforcer.usage(key) %>
        <div style="padding:.75rem 1.25rem;border-bottom:1px solid #f9fafb">
          <div style="display:flex;justify-content:space-between;margin-bottom:.35rem">
            <span style="font-size:.85rem;color:#374151"><%= FEATURE_LABELS[key] %></span>
            <span style="font-size:.82rem;color:#6b7280">
              <% if u[:unlimited] %>
                <%= u[:used] %> / unlimited
              <% else %>
                <%= u[:used] %> / <%= u[:limit] %>
              <% end %>
            </span>
          </div>
          <% unless u[:unlimited] %>
            <div style="background:#f3f4f6;border-radius:4px;height:6px;overflow:hidden">
              <div style="background:<%= u[:percent] >= 90 ? '#dc2626' : u[:percent] >= 70 ? '#f59e0b' : '#2563eb' %>;
                          height:100%;width:<%= u[:percent] %>%;transition:width .3s"></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Feature access summary %>
  <% if @plan %>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden">
      <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.88rem;font-weight:700;color:#111">
        Your plan features
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
        <% @plan.plan_features.order(:display_order).each do |f| %>
          <div style="padding:.65rem 1.25rem;border-bottom:1px solid #f9fafb;display:flex;align-items:center;gap:.5rem">
            <% if f.boolean_feature? %>
              <span style="color:<%= f.typed_value ? '#059669' : '#d1d5db' %>">
                <%= f.typed_value ? "✓" : "✗" %>
              </span>
            <% else %>
              <span style="color:#2563eb;font-weight:700;font-size:.82rem">
                <%= f.unlimited? ? "∞" : f.typed_value %>
              </span>
            <% end %>
            <span style="font-size:.83rem;color:#374151"><%= f.display_name %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
