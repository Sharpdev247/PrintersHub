<% content_for :title, "Order #{@order.order_number} — Seller" %>

<%
  NEXT_STATUSES = {
    "pending_payment"   => %w[payment_confirmed cancelled],
    "payment_confirmed" => %w[processing cancelled],
    "processing"        => %w[partially_shipped shipped cancelled],
    "partially_shipped" => %w[shipped],
    "shipped"           => %w[delivered],
    "delivered"         => %w[completed refunded],
    "completed"         => %w[refunded],
  }.freeze
%>

<div style="max-width:860px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem">
    <div>
      <%= link_to "← Orders", portal_seller_orders_path,
            style: "font-size:.82rem;color:#6b7280;text-decoration:none" %>
      <h1 style="font-size:1.2rem;font-weight:700;color:#111;margin:.3rem 0 0">
        Order <span style="font-family:monospace"><%= @order.order_number %></span>
      </h1>
      <div style="font-size:.8rem;color:#9ca3af;margin-top:.15rem">
        Buyer: <%= @order.buyer_account.name %> · Placed <%= @order.created_at.strftime("%b %d, %Y") %>
      </div>
    </div>
    <%= render "portal/shared/order_status_badge", status: @order.status %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 320px;gap:1rem;align-items:start">
    <%# Left: items + history %>
    <div>
      <%# Order items %>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;margin-bottom:1rem">
        <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.88rem;font-weight:700;color:#111">
          Items (<%= @order.order_items.size %>)
        </div>
        <% @order.order_items.each do |item| %>
          <div style="padding:.9rem 1.25rem;border-top:1px solid #f9fafb;display:flex;justify-content:space-between;gap:1rem">
            <div style="flex:1;min-width:0">
              <div style="font-size:.88rem;font-weight:600;color:#111">
                <%= item.listing_snapshot&.dig("title") || item.listing&.title || "Listing removed" %>
              </div>
              <div style="font-size:.77rem;color:#9ca3af;margin-top:.15rem">
                Qty: <%= item.quantity %> ·
                <%= number_to_currency(item.unit_price, unit: item.currency + " ") %> each ·
                Shipped: <%= item.quantity_shipped %>/<%= item.quantity %>
              </div>
            </div>
            <div style="font-size:.92rem;font-weight:700;color:#111;flex-shrink:0">
              <%= number_to_currency(item.total, unit: item.currency + " ") %>
            </div>
          </div>
        <% end %>
        <div style="padding:.85rem 1.25rem;border-top:1px solid #e5e7eb;background:#f9fafb;
                    display:flex;justify-content:flex-end;gap:2rem">
          <div style="font-size:.85rem;color:#6b7280">
            Subtotal: <%= number_to_currency(@order.subtotal, unit: @order.currency + " ") %>
          </div>
          <div style="font-size:.95rem;font-weight:700;color:#111">
            Total: <%= number_to_currency(@order.total, unit: @order.currency + " ") %>
          </div>
        </div>
      </div>

      <%# Status history %>
      <% if @history.any? %>
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
          <div style="padding:.9rem 1.25rem;border-bottom:1px solid #f3f4f6;font-size:.88rem;font-weight:700;color:#111">
            History
          </div>
          <% @history.each do |h| %>
            <div style="padding:.75rem 1.25rem;border-top:1px solid #f9fafb;display:flex;gap:.75rem">
              <div style="width:6px;height:6px;border-radius:50%;background:#2563eb;margin-top:.45rem;flex-shrink:0"></div>
              <div>
                <div style="font-size:.82rem;color:#374151;font-weight:500">
                  <%= Order.statuses.key(h.from_status)&.humanize %> →
                  <%= Order.statuses.key(h.to_status)&.humanize %>
                </div>
                <% if h.note.present? %>
                  <div style="font-size:.77rem;color:#6b7280;margin-top:.1rem"><%= h.note %></div>
                <% end %>
                <div style="font-size:.72rem;color:#9ca3af;margin-top:.15rem">
                  <%= h.created_at.strftime("%b %d, %Y %I:%M %p") %> · <%= h.source %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Right: actions %>
    <div>
      <% allowed_next = NEXT_STATUSES[@order.status] || [] %>
      <% if policy(@order).update? && allowed_next.any? %>
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.25rem;margin-bottom:1rem">
          <div style="font-size:.88rem;font-weight:700;color:#111;margin-bottom:.9rem">Update Status</div>
          <%= form_with url: update_status_portal_seller_order_path(@order), method: :patch do |f| %>
            <div style="margin-bottom:.75rem">
              <%= f.select :status,
                    allowed_next.map { |s| [s.humanize, s] },
                    { prompt: "Move to…" },
                    style: "width:100%;padding:.5rem;border:1px solid #d1d5db;border-radius:6px;font-size:.88rem" %>
            </div>
            <div style="margin-bottom:.75rem">
              <%= f.text_field :note,
                    placeholder: "Note (optional)",
                    style: "width:100%;padding:.5rem .75rem;border:1px solid #d1d5db;border-radius:6px;font-size:.85rem" %>
            </div>
            <%= f.submit "Update",
                  style: "width:100%;padding:.55rem;background:#2563eb;color:#fff;border:none;border-radius:6px;font-size:.88rem;font-weight:600;cursor:pointer" %>
          <% end %>
        </div>
      <% end %>

      <% if policy(@order).cancel? && @order.cancellable? %>
        <div style="background:#fff;border:1px solid #fca5a5;border-radius:10px;padding:1.25rem">
          <div style="font-size:.85rem;font-weight:700;color:#dc2626;margin-bottom:.75rem">Cancel Order</div>
          <%= form_with url: cancel_portal_seller_order_path(@order), method: :patch do |f| %>
            <div style="margin-bottom:.75rem">
              <%= f.text_field :reason,
                    placeholder: "Cancellation reason",
                    style: "width:100%;padding:.5rem .75rem;border:1px solid #fca5a5;border-radius:6px;font-size:.85rem" %>
            </div>
            <%= f.submit "Cancel order",
                  data: { confirm: "Cancel order #{@order.order_number}?" },
                  style: "width:100%;padding:.5rem;background:#fee2e2;color:#dc2626;border:1px solid #fca5a5;border-radius:6px;font-size:.85rem;font-weight:600;cursor:pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
