<% content_for :title, "Seller Dashboard — PrintersHub" %>
<% content_for :breadcrumb do %>
  Dashboard
<% end %>

<%# ── Welcome header ───────────────────────────────────────────────────────── %>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem">
  <div>
    <h1 style="font-size:1.5rem;font-weight:700;color:#111;margin-bottom:.2rem">
      Welcome back<%= current_user.full_name.present? ? ", #{current_user.full_name.split.first}" : "" %>
    </h1>
    <p style="font-size:.9rem;color:#6b7280"><%= Current.account.name %> · <%= Current.membership&.role&.humanize %></p>
  </div>
  <%= link_to "＋ New Listing", new_portal_seller_listing_path,
        style: "padding:.6rem 1.25rem;background:#2563eb;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;font-size:.9rem" %>
</div>

<%# ── Stats grid ───────────────────────────────────────────────────────────── %>
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem">
  <%
    stat_cards = [
      { label: "Total Listings",  value: @stats[:total_listings], color: "#2563eb", bg: "#eff6ff" },
      { label: "Published",       value: @stats[:published],      color: "#16a34a", bg: "#f0fdf4" },
      { label: "Total Views",     value: @stats[:total_views],    color: "#7c3aed", bg: "#f5f3ff" },
      { label: "Favorites",       value: @stats[:total_favorites],color: "#db2777", bg: "#fdf2f8" },
    ]
  %>
  <% stat_cards.each do |card| %>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.25rem">
      <div style="font-size:.8rem;font-weight:600;color:#6b7280;margin-bottom:.5rem"><%= card[:label] %></div>
      <div style="font-size:2rem;font-weight:800;color:<%= card[:color] %>"><%= number_with_delimiter(card[:value]) %></div>
    </div>
  <% end %>
</div>

<%# ── Secondary stats row ─────────────────────────────────────────────────── %>
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem">
  <%
    mini_cards = [
      { label: "Draft",   value: @stats[:draft],  color: "#6b7280" },
      { label: "Paused",  value: @stats[:paused], color: "#ca8a04" },
      { label: "Sold",    value: @stats[:sold],   color: "#dc2626" },
    ]
  %>
  <% mini_cards.each do |card| %>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1rem;display:flex;justify-content:space-between;align-items:center">
      <span style="font-size:.85rem;color:#6b7280;font-weight:500"><%= card[:label] %></span>
      <span style="font-size:1.25rem;font-weight:700;color:<%= card[:color] %>"><%= card[:value] %></span>
    </div>
  <% end %>
</div>

<%# ── Two-column lower section ────────────────────────────────────────────── %>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">

  <%# Recent listings %>
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
    <div style="padding:1rem 1.25rem;border-bottom:1px solid #f0f0f0;display:flex;justify-content:space-between;align-items:center">
      <h2 style="font-size:.95rem;font-weight:700;color:#111">Recently Updated</h2>
      <%= link_to "View all →", portal_seller_listings_path,
            style: "font-size:.8rem;color:#2563eb;text-decoration:none" %>
    </div>
    <% if @recent_listings.empty? %>
      <div style="padding:2rem;text-align:center;color:#9ca3af;font-size:.88rem">
        No listings yet.
        <%= link_to "Create one", new_portal_seller_listing_path, style: "color:#2563eb" %>
      </div>
    <% else %>
      <% @recent_listings.each do |listing| %>
        <div style="padding:.75rem 1.25rem;border-bottom:1px solid #f9fafb;display:flex;justify-content:space-between;align-items:center">
          <div style="min-width:0">
            <%= link_to truncate(listing.title, length: 40),
                  portal_seller_listing_path(listing),
                  style: "font-size:.88rem;font-weight:500;color:#1d4ed8;text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" %>
            <span style="font-size:.75rem;color:#9ca3af"><%= listing.category.name %></span>
          </div>
          <div style="text-align:right;flex-shrink:0;margin-left:1rem">
            <%
              status_color = {
                "published" => "#16a34a", "draft" => "#6b7280",
                "paused" => "#ca8a04",    "sold" => "#dc2626", "archived" => "#9ca3af"
              }[listing.status] || "#6b7280"
            %>
            <span style="font-size:.72rem;color:<%= status_color %>;font-weight:600">
              <%= listing.status.upcase %>
            </span>
            <div style="font-size:.8rem;font-weight:600;color:#111;margin-top:.1rem">
              <%= number_to_currency(listing.price, unit: listing.currency + " ", precision: 0) %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Top listings by views %>
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden">
    <div style="padding:1rem 1.25rem;border-bottom:1px solid #f0f0f0">
      <h2 style="font-size:.95rem;font-weight:700;color:#111">Top by Views</h2>
    </div>
    <% if @top_listings.empty? %>
      <div style="padding:2rem;text-align:center;color:#9ca3af;font-size:.88rem">
        No published listings yet.
      </div>
    <% else %>
      <% @top_listings.each_with_index do |listing, i| %>
        <div style="padding:.75rem 1.25rem;border-bottom:1px solid #f9fafb;display:flex;align-items:center;gap:.75rem">
          <span style="font-size:.8rem;font-weight:700;color:#d1d5db;width:1.25rem;text-align:center"><%= i + 1 %></span>
          <div style="flex:1;min-width:0">
            <%= link_to truncate(listing.title, length: 38),
                  portal_seller_listing_path(listing),
                  style: "font-size:.88rem;font-weight:500;color:#1d4ed8;text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" %>
            <span style="font-size:.75rem;color:#9ca3af"><%= listing.brand&.name %></span>
          </div>
          <div style="text-align:right;flex-shrink:0">
            <div style="font-size:.85rem;font-weight:600;color:#7c3aed"><%= listing.views_count %> views</div>
            <div style="font-size:.75rem;color:#9ca3af"><%= listing.favorites.count %> ♥</div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

</div>

<%# ── Quick actions ────────────────────────────────────────────────────────── %>
<div style="margin-top:1.5rem;background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:1.25rem">
  <h2 style="font-size:.9rem;font-weight:700;color:#111;margin-bottom:1rem">Quick Actions</h2>
  <div style="display:flex;gap:.75rem;flex-wrap:wrap">
    <%= link_to "＋ New Listing", new_portal_seller_listing_path,
          style: "padding:.5rem 1rem;background:#2563eb;color:#fff;border-radius:6px;text-decoration:none;font-size:.85rem;font-weight:500" %>
    <%= link_to "My Listings", portal_seller_listings_path,
          style: "padding:.5rem 1rem;background:#fff;color:#374151;border:1px solid #d1d5db;border-radius:6px;text-decoration:none;font-size:.85rem;font-weight:500" %>
    <%= link_to "Browse Marketplace", listings_path,
          style: "padding:.5rem 1rem;background:#fff;color:#374151;border:1px solid #d1d5db;border-radius:6px;text-decoration:none;font-size:.85rem;font-weight:500" %>
  </div>
</div>
