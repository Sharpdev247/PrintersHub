<%#
  Notification bell icon for the portal top bar.
  Shows unread count badge. Renders a small dropdown of the 5 most recent notifications.
%>
<% unread_count = current_user.notifications.unread.count %>
<% recent_notifs = current_user.notifications.recent.limit(5) %>

<div style="position:relative;display:inline-block" id="notification-bell">
  <button onclick="document.getElementById('notif-dropdown').classList.toggle('hidden')"
          style="background:none;border:none;cursor:pointer;padding:.4rem;position:relative;font-size:1.1rem;
                 color:#374151;border-radius:6px;display:flex;align-items:center">
    🔔
    <% if unread_count > 0 %>
      <span style="position:absolute;top:0;right:0;background:#dc2626;color:#fff;border-radius:999px;
                   font-size:.6rem;font-weight:700;min-width:16px;height:16px;
                   display:flex;align-items:center;justify-content:center;padding:0 3px">
        <%= unread_count > 99 ? "99+" : unread_count %>
      </span>
    <% end %>
  </button>

  <div id="notif-dropdown"
       class="hidden"
       style="position:absolute;right:0;top:calc(100% + 6px);width:340px;
              background:#fff;border:1px solid #e5e7eb;border-radius:10px;
              box-shadow:0 4px 20px rgba(0,0,0,.1);z-index:200;overflow:hidden">

    <div style="padding:.75rem 1rem;border-bottom:1px solid #f3f4f6;
                display:flex;justify-content:space-between;align-items:center">
      <span style="font-size:.85rem;font-weight:700;color:#111">Notifications</span>
      <% if unread_count > 0 %>
        <%= button_to "Mark all read", mark_all_read_portal_notifications_path,
              method: :patch,
              style: "font-size:.72rem;color:#2563eb;background:none;border:none;cursor:pointer;padding:0;font-weight:500" %>
      <% end %>
    </div>

    <% if recent_notifs.none? %>
      <div style="padding:1.5rem;text-align:center;font-size:.85rem;color:#9ca3af">
        No notifications yet
      </div>
    <% else %>
      <% recent_notifs.each do |n| %>
        <%= link_to portal_notification_path(n),
              style: "display:block;padding:.75rem 1rem;text-decoration:none;
                      border-bottom:1px solid #f9fafb;
                      background:#{n.read? ? '#fff' : '#eff6ff'}" do %>
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem">
            <div style="flex:1;min-width:0">
              <div style="font-size:.82rem;font-weight:#{n.read? ? '400' : '600'};color:#111;
                          white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                <%= n.title %>
              </div>
              <% if n.body.present? %>
                <div style="font-size:.75rem;color:#6b7280;margin-top:.15rem;
                            white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  <%= n.body %>
                </div>
              <% end %>
            </div>
            <div style="font-size:.7rem;color:#9ca3af;flex-shrink:0;margin-top:.1rem">
              <%= time_ago_in_words(n.created_at) %>
            </div>
          </div>
        <% end %>
      <% end %>

      <%= link_to "View all notifications →", portal_notifications_path,
            style: "display:block;padding:.7rem 1rem;font-size:.8rem;font-weight:600;
                    color:#2563eb;text-decoration:none;text-align:center;
                    border-top:1px solid #f3f4f6;background:#f9fafb" %>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("click", function(e) {
    var bell = document.getElementById("notification-bell");
    var dropdown = document.getElementById("notif-dropdown");
    if (bell && dropdown && !bell.contains(e.target)) {
      dropdown.classList.add("hidden");
    }
  });
</script>
