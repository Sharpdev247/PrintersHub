<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Portal — PrintersHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
             background: #f3f4f6; color: #111; min-height: 100vh; }
      a { color: inherit; }
      .hidden { display: none !important; }
    </style>
  </head>

  <body style="display:flex;min-height:100vh">

    <%# ── Sidebar ─────────────────────────────────────────────────────────── %>
    <aside style="width:240px;background:#1e293b;color:#cbd5e1;display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;left:0;height:100vh;overflow-y:auto;z-index:100">

      <%# Brand %>
      <div style="padding:1.25rem 1.5rem;border-bottom:1px solid #334155">
        <%= link_to root_path, style: "text-decoration:none" do %>
          <span style="font-size:1.1rem;font-weight:800;color:#fff">Printers<span style="color:#3b82f6">Hub</span></span>
        <% end %>
        <% if Current.account %>
          <div style="font-size:.72rem;color:#64748b;margin-top:.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
            <%= Current.account.name %>
          </div>
        <% end %>
      </div>

      <%# Nav links %>
      <nav style="flex:1;padding:.75rem 0">
        <% nav_link = ->(label, path, icon="•") do %>
          <% active = request.path.start_with?(path.gsub(/\/$/, "")) %>
          <%= link_to path,
                style: "display:flex;align-items:center;gap:.65rem;padding:.6rem 1.5rem;font-size:.88rem;text-decoration:none;
                        color:#{active ? '#fff' : '#94a3b8'};
                        background:#{active ? 'rgba(59,130,246,.18)' : 'transparent'};
                        border-left:3px solid #{active ? '#3b82f6' : 'transparent'}" do %>
            <span style="font-size:1rem"><%= icon %></span>
            <%= label %>
          <% end %>
        <% end %>

        <div style="padding:.25rem 1.5rem .5rem;font-size:.68rem;font-weight:700;color:#475569;letter-spacing:.08em;text-transform:uppercase;margin-top:.5rem">
          Overview
        </div>
        <%= nav_link.call("Dashboard",  portal_path,        "⊞") %>

        <div style="padding:.75rem 1.5rem .5rem;font-size:.68rem;font-weight:700;color:#475569;letter-spacing:.08em;text-transform:uppercase">
          Marketplace
        </div>
        <%= nav_link.call("My Listings", portal_seller_listings_path, "◈") %>
        <%= nav_link.call("Browse",      listings_path,               "⊙") %>

        <div style="padding:.75rem 1.5rem .5rem;font-size:.68rem;font-weight:700;color:#475569;letter-spacing:.08em;text-transform:uppercase">
          Account
        </div>
        <%= nav_link.call("Settings",   "#",  "⚙") %>
        <%= nav_link.call("Team",        "#",  "👥") %>
      </nav>

      <%# User footer %>
      <div style="padding:1rem 1.5rem;border-top:1px solid #334155;font-size:.82rem">
        <div style="color:#e2e8f0;font-weight:600"><%= current_user.full_name.presence || current_user.email %></div>
        <div style="color:#64748b;font-size:.75rem;margin-bottom:.6rem"><%= Current.membership&.role&.humanize %></div>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete },
              style: "font-size:.78rem;color:#64748b;text-decoration:none" %>
      </div>
    </aside>

    <%# ── Main area ────────────────────────────────────────────────────────── %>
    <div style="flex:1;margin-left:240px;min-height:100vh;display:flex;flex-direction:column">

      <%# Top bar %>
      <header style="background:#fff;border-bottom:1px solid #e5e7eb;padding:.75rem 2rem;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:50">
        <div style="font-size:.9rem;color:#6b7280">
          <%= content_for?(:breadcrumb) ? yield(:breadcrumb) : "" %>
        </div>
        <div style="display:flex;align-items:center;gap:1rem">
          <% if Current.user.accounts.kept.count > 1 %>
            <span style="font-size:.8rem;color:#9ca3af">Account:</span>
            <%= form_with url: portal_path, method: :get, local: true, style: "display:inline" do |f| %>
              <%= f.select :switch_account,
                    Current.user.accounts.kept.map { |a| [a.name, a.id] },
                    { selected: Current.account&.id },
                    onchange: "this.form.submit()",
                    style: "font-size:.8rem;border:1px solid #e5e7eb;border-radius:5px;padding:.25rem .5rem;color:#374151" %>
            <% end %>
          <% end %>
          <%= render "portal/shared/notification_bell" %>
          <%= link_to listings_path, style: "font-size:.8rem;color:#3b82f6;text-decoration:none" do %>
            View marketplace →
          <% end %>
        </div>
      </header>

      <%# Flash messages %>
      <% if notice %>
        <div style="background:#f0fdf4;border-left:4px solid #22c55e;padding:.75rem 2rem;font-size:.88rem;color:#15803d">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div style="background:#fef2f2;border-left:4px solid #ef4444;padding:.75rem 2rem;font-size:.88rem;color:#dc2626">
          <%= alert %>
        </div>
      <% end %>

      <%# Page content %>
      <main style="flex:1;padding:2rem">
        <%= yield %>
      </main>
    </div>

  </body>
</html>
